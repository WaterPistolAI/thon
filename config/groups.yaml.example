#THON - Groups Configuration
#
# Define groups and individuals for sandbox instance allocation.
# Each user gets their own VS Code sandbox instance with a workspace
# at /workspace/{group}/{username}.
#
# The event_id uniquely identifies this event (hackathon, workshop).
# Reloading the same file with the same event_id will not duplicate
# groups or users. You can also set THON_EVENT_ID and THON_EVENT_TITLE
# as environment variables.
#
# Usage:
#   # Run all groups
#   python ./scripts/main.py --groups groups.yaml
#
#   # Run a single group
#   python ./scripts/main.py --groups groups.yaml --group alpha
#
#   # Run with secure auth (generates per-user passwords)
#   python ./scripts/main.py --groups groups.yaml --secure

event_id: hackathon-2025-spring
title: "Spring Hackathon 2025"

groups:
  alpha:
    title: "Team Alpha"
    users:
      - alice
      - bob
      - carol

  beta:
    title: "Team Beta"
    users:
      - dave
      - eve

  gamma:
    users:
      - frank
