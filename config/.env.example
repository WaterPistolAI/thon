# THON Environment Configuration
# Copy to .env and customize. Values here are defaults; CLI flags take precedence.
# Alternatively, set THON_ENV_FILE to point to a custom .env path.

# ── Workspace / Storage ──────────────────────────────────────────────
# Host directory for persistent workspace bind mounts
# Each user gets: {THON_WORKSPACE_DIR}/{group}/{username}
# Default: ~/.thon/workspace
THON_WORKSPACE_DIR=

# ── Database ─────────────────────────────────────────────────────────
# SQLite database path (default: ~/.thon/thon.db)
THON_DB_PATH=

# ── Sandbox Server ───────────────────────────────────────────────────
# Sandbox server address
SANDBOX_DOMAIN=localhost:8080
# Sandbox API key (optional)
SANDBOX_API_KEY=
# Docker image for sandboxes
SANDBOX_IMAGE=waterpistol/thon:latest

# ── Dashboard ────────────────────────────────────────────────────────
# Dashboard bind address
DASHBOARD_HOST=0.0.0.0
# Dashboard port
DASHBOARD_PORT=8100
# FastAPI secret key
DASHBOARD_SECRET_KEY=
# Enable debug/reload mode
DASHBOARD_DEBUG=false

# ── External IP ──────────────────────────────────────────────────────
# External IP for SSL cert SAN and URLs (auto-detected if omitted)
EXTERNAL_IP=

# ── Lemonade Server ──────────────────────────────────────────────────
# Lemonade server bind address
LEMONADE_HOST=0.0.0.0
# Lemonade server port
LEMONADE_PORT=13305
# Lemonade API key
LEMONADE_API_KEY=
# Lemonade admin API key
LEMONADE_ADMIN_API_KEY=
# Lemonade config directory
LEMONADE_CONFIG_DIR=/var/lib/lemonade/.cache/lemonade

# ── Authentication ───────────────────────────────────────────────────
# Enable OIDC authentication
AUTH_ENABLED=false
# HMAC secret for session tokens
AUTH_SESSION_SECRET=
# GitHub OAuth
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
# GitLab OAuth
AUTH_GITLAB_CLIENT_ID=
AUTH_GITLAB_CLIENT_SECRET=
# LinkedIn OIDC
AUTH_LINKEDIN_CLIENT_ID=
AUTH_LINKEDIN_CLIENT_SECRET=
