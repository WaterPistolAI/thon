# THON Environment Configuration
# Copy to .env and customize. Values here are defaults; CLI flags take precedence.
# Alternatively, set THON_ENV_FILE to point to a custom .env path.
#
# RECOMMENDED: Use `thon init` to generate a thon.yaml config, then
# `thon config env` to export this .env file automatically.

# ── Workspace / Storage ──────────────────────────────────────────────
# Host directory for persistent workspace bind mounts
# Each user gets: {THON_WORKSPACE_DIR}/{group}/{username}
# Default: ~/.thon/workspace
THON_WORKSPACE_DIR=

# ── Database ─────────────────────────────────────────────────────────
# SQLite database path (default: ~/.thon/thon.db)
THON_DB_PATH=

# ── Sandbox Server ───────────────────────────────────────────────────
# Sandbox server address
SANDBOX_DOMAIN=localhost:8080
# Sandbox API key (optional)
SANDBOX_API_KEY=
# Docker image for sandboxes
SANDBOX_IMAGE=waterpistol/thon:latest

# ── Dashboard ────────────────────────────────────────────────────────
# Dashboard bind address
DASHBOARD_HOST=0.0.0.0
# Dashboard port
DASHBOARD_PORT=8100
# FastAPI secret key
DASHBOARD_SECRET_KEY=
# Enable debug/reload mode
DASHBOARD_DEBUG=false

# ── External IP ──────────────────────────────────────────────────────
# External IP for SSL cert SAN and URLs (auto-detected if omitted)
EXTERNAL_IP=

# ── Lemonade Server ──────────────────────────────────────────────────
# Lemonade server bind address
LEMONADE_HOST=0.0.0.0
# Lemonade server port
LEMONADE_PORT=13305
# Lemonade API key
LEMONADE_API_KEY=
# Lemonade admin API key
LEMONADE_ADMIN_API_KEY=
# Lemonade config directory
LEMONADE_CONFIG_DIR=/var/lib/lemonade/.cache/lemonade

# ── AI Gateway (APISIX) ──────────────────────────────────────────────
# Enable AI Gateway features in dashboard
GATEWAY_ENABLED=false
# APISIX Admin API URL
GATEWAY_ADMIN_URL=http://127.0.0.1:9180
# APISIX Admin API key
GATEWAY_ADMIN_KEY=edd1c9f034335f136f87ad84b625c8f1
# APISIX proxy port
GATEWAY_PROXY_PORT=9080
# Redis host for rate limiting (empty = local policy)
GATEWAY_REDIS_HOST=
# Redis port
GATEWAY_REDIS_PORT=6379
# Redis password
GATEWAY_REDIS_PASSWORD=
# Token limit per consumer per time window
GATEWAY_RATE_LIMIT_TOKENS=500
# Rate limit time window in seconds
GATEWAY_RATE_LIMIT_WINDOW=60
# Consumer mode: per-user or per-group
GATEWAY_MODE=per-user

# ── Authentication ───────────────────────────────────────────────────
# Enable OIDC authentication
AUTH_ENABLED=false
# HMAC secret for session tokens
AUTH_SESSION_SECRET=
# GitHub OAuth
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
# GitLab OAuth
AUTH_GITLAB_CLIENT_ID=
AUTH_GITLAB_CLIENT_SECRET=
# LinkedIn OIDC
AUTH_LINKEDIN_CLIENT_ID=
AUTH_LINKEDIN_CLIENT_SECRET=
