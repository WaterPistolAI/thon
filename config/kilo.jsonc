{
  "$schema": "https://app.kilo.ai/config.json",
  "experimental": {
    "batch_tool": false,
    "codebase_search": true,
    "openTelemetry": true,
    "continue_loop_on_deny": true,
    "semantic_indexing": true,
    "agent_manager_tool": false
  },
  "indexing": {
    "enabled": true,
    "provider": "openai-compatible",
    "vectorStore": "lancedb",
    "openai-compatible": {
      "baseUrl": "http://52.162.90.16:13305/v1",
      "apiKey": "AmnVwR6GLuJh3CN-sFQlmS4Q6LPY5thU",
      "model": "user.harrier-oss-v1-0.6b"
    }
  },
  "mcp": {
    "git-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@cyanheads/git-mcp-server@latest"
      ],
      "environment": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "MCP_LOG_LEVEL": "info",
        "GIT_BASE_DIR": "$WORKSPACE",
        "LOGS_DIR": "$WORKSPACE/.logs/git-mcp-server",
        "GIT_USERNAME": "$THON_USERNAME",
        "GIT_EMAIL": "$THON_USER_EMAIL",
        "GIT_SIGN_COMMITS": "true"
      },
      "enabled": true
    }
  },
  "model": "lemonade/user.gemma-4-31b-it",
  "provider": {
    "lemonade": {
      "models": {
        "user.gemma-4-31b-it": {
          "name": "unsloth/gemma-4-31B-it-GGUF:Q8_K_XL",
          "limit": {
            "context": 262144,
            "output": 4096
          }
        }
      },
      "options": {
        "apiKey": "AmnVwR6GLuJh3CN-sFQlmS4Q6LPY5thU",
        "baseURL": "http://52.162.90.16:13305/v1",
        "timeout": false
      }
    }
  }
}