{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "lemonade/user.gemma-4-31b-it",
  "provider": {
    "lemonade": {
      "models": {
        "user.gemma-4-31b-it": {
          "name": "unsloth/gemma-4-31B-it-GGUF:Q8_K_XL",
          "limit": {
            "context": 262144,
            "output": 4096
          }
        }
      },
      "options": {
        "apiKey": "PLACEHOLDER",
        "baseURL": "http://localhost:13305/v1",
        "timeout": false
      }
    }
  },
  "experimental": {
    "batch_tool": false,
    "codebase_search": true,
    "openTelemetry": false,
    "continue_loop_on_deny": true,
    "semantic_indexing": true,
    "agent_manager_tool": true
  },
  "indexing": {
    "enabled": true,
    "provider": "openai-compatible",
    "vectorStore": "lancedb",
    "openai-compatible": {
      "baseUrl": "http://localhost:13305/v1",
      "apiKey": "PLACEHOLDER",
      "model": "user.harrier-oss-v1-0.6b"
    }
  }
}

// To enable Langfuse observability, add the plugin array and set openTelemetry to true:
// {
//   "experimental": { "openTelemetry": true },
//   "plugin": ["opencode-plugin-langfuse"]
// }
// Also set env vars: LANGFUSE_PUBLIC_KEY, LANGFUSE_SECRET_KEY, LANGFUSE_BASEURL
