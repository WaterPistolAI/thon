{
  "$schema": "https://app.kilo.ai/config.json",
  "experimental": {
    "batch_tool": false,
    "codebase_search": true,
    "openTelemetry": false,
    "continue_loop_on_deny": true,
    "semantic_indexing": true,
    "agent_manager_tool": false
  },
  "indexing": {
    "enabled": true,
    "provider": "openai-compatible",
    "vectorStore": "lancedb",
    "openai-compatible": {
      "model": "user.harrier-oss-v1-0.6b",
      "baseUrl": "http://172.17.0.1:13305/v1",
      "apiKey": "AckOFY866i0hMX5P5h0PLZYhXrDJnozm"
    }
  },
  "mcp": {
    "git-mcp-server": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@cyanheads/git-mcp-server@latest"
      ],
      "environment": {
        "MCP_TRANSPORT_TYPE": "stdio",
        "MCP_LOG_LEVEL": "info",
        "GIT_BASE_DIR": "$WORKSPACE",
        "LOGS_DIR": "$WORKSPACE/.logs/git-mcp-server",
        "GIT_USERNAME": "$USERNAME",
        "GIT_EMAIL": "$EMAIL",
        "GIT_SIGN_COMMITS": "true"
      },
      "enabled": true
    }
  },
  "provider": {
    "lemonade": {
      "models": {
        "user.gemma-4-31b-it": {
          "name": "unsloth/gemma-4-31B-it-GGUF:Q8_K_XL",
          "limit": {
            "context": 262144,
            "output": 4096
          }
        }
      },
      "options": {
        "apiKey": "AckOFY866i0hMX5P5h0PLZYhXrDJnozm",
        "baseURL": "http://172.17.0.1:13305/v1"
      }
    }
  },
  "model": "lemonade/user.gemma-4-31b-it"
}